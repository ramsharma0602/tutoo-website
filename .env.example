# Optional. Only set this if your backend API lives on a DIFFERENT domain
# than the frontend (e.g. https://api.tutoo.com/). If unset, the app
# automatically uses the current site's own domain as the API base URL.
# Must include a trailing slash.
VITE_API_BASE_URL=http://127.0.0.1:8000/

# For local development against a backend running on your machine:
VITE_API_BASE_URL=http://127.0.0.1:8000/
